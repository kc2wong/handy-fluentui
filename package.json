{
  "name": "handy-fluentui",
  "version": "0.1.0",
  "description": "Handy React components built on top of FluentUI v9 with responsive, form-friendly behaviours",
  "license": "MIT",
  "keywords": [
    "react",
    "fluentui",
    "components",
    "form",
    "ui",
    "responsive"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:test": "tsc -p tsconfig.test.json",
    "build:lib": "vite build --config vite.config.lib.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@fluentui/react-components": "^9.0.0",
    "@fluentui/react-calendar-compat": ">=0.1.0",
    "@fluentui/react-datepicker-compat": ">=0.1.0",
    "@fluentui/react-icons": "^2.0.0",
    "usehooks-ts": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@fluentui/react-calendar-compat": "^0.4.1",
    "@fluentui/react-components": "^9.73.8",
    "@fluentui/react-datepicker-compat": "^0.6.31",
    "@fluentui/react-icons": "^2.0.324",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.2.1",
    "@types/jest": "^27.0.1",
    "@types/node": "^16.7.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-vitest": "^0.5.4",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.0",
    "usehooks-ts": "^3.1.1",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4",
    "web-vitals": "^2.1.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
