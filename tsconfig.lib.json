{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": [
    "src/main.tsx",
    "src/App.tsx",
    "src/App.css",
    "src/setupTests.ts",
    "src/reportWebVitals.ts",
    "src/react-app-env.d.ts",
    "**/*.spec.tsx",
    "**/*.spec.ts"
  ]
}
